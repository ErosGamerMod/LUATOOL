def patch_bgmi_structure(std_bytecode: bytes, original_bgmi: bytes) -> bytes:
    
    # Cria um reader para o bytecode padrão compilado
    r_std = _R(std_bytecode)
    # Cria um writer para o novo arquivo BGMI
    w = _W()
    
    # 1. Copia o cabeçalho original (mantendo magic e versão customizada do jogo)
    w.raw(original_bgmi[:HEADER_SIZE])
    
    # 2. Pula o byte inicial do reader de bytecode padrão
    r_std.p = HEADER_SIZE
    w.byte(r_std.byte())
    
    # 3. Executa a conversão via _cvt_func invertendo o processo (std -> bgmi)
    # Aqui usamos to_std=False para forçar a escrita das strings e opcodes no formato do jogo
    stats = {'clamped': 0, 'custom_preserved': 0}
    _cvt_func(r_std, w, to_std=False, stats=stats)
    
    return w.get()

def patch_with_template(new_bytecode_path: Path, template_name: str):
    template_path = STD_DIR / template_name
    template_data = template_path.read_bytes()
    new_data = new_bytecode_path.read_bytes()

    # O "Magic" do Lua é \x1bLua. 
    # O início real do bloco de código principal (Proto) geralmente 
    # vem logo após a contagem de constantes.
    # Em vez de 280, procuramos o padrão de bytes que o JOGO sempre espera:
    
    # Exemplo: Procurar por um padrão que marca o início do código da função main
    # Isso varia pouco entre arquivos do mesmo jogo
    signature = b'\x00\x00\x00\x00\x01\x00\x00\x00' # Exemplo de padrão de início de bloco
    
    # Se você encontrar a assinatura, o corte é dinâmico!
    split_point = template_data.find(signature)
    
    if split_point == -1:
        # Fallback: Se não achar, usa um corte de segurança ou falha com aviso
        tprint("  ❌ Assinatura não encontrada, abortando...", Theme.ERROR)
        return None

    # Montagem Dinâmica
    final_bytes = template_data[:split_point] + new_data[split_point:]
    
    return final_bytes

