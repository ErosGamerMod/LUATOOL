# TRANSLATION ENGINE FUNCTIONS
# ============================================================

def _cvt_func(r: _R, w: _W, to_std: bool, stats: dict, op_map: dict = None):
    # Definindo os métodos de leitura/escrita baseados na direção
    if to_std:
        read_str = r.bgmi_str
        write_str = w.std_str
    else:
        read_str = r.std_str
        write_str = w.bgmi_str
    
    # Registro de Opcode Original no mapa
    orig_offset = r.p
    op = r.byte()
    if op_map is not None:
        op_map[orig_offset] = op
    r.p = orig_offset  # Volta para processar o byte corretamente

    opmap = BGMI_TO_STD if to_std else STD_TO_BGMI
    
    write_str(read_str())
    w.i32(r.i32())
    ldef_val = struct.unpack('<i', bytes(w.b[-4:]))[0]
    w.i32(r.i32())
    w.byte(r.byte()); w.byte(r.byte()); w.byte(r.byte())

    # --- INSTRUÇÕES ---
    csz = r.u32()
    if csz > 100000: csz = 0
    w.u32(csz)
    inst_meta = []
    
    for idx in range(csz):
        # PROTEÇÃO ANTI-CRASH: Verifica fim de arquivo ou preenchimento
        if r.p >= r.max_p: break
        
        raw_i = r.u32()
        
        # Pula bytes de padding se encontrar alinhamento nulo (0x00)
        if raw_i == 0 and idx > 0:
            continue

        bop = raw_i & 0x3F
        A = (raw_i >> 6) & 0xFF
        C = (raw_i >> 14) & 0x1FF
        B = (raw_i >> 23) & 0x1FF
        Bx = (raw_i >> 14) & 0x3FFFF
        Ax = (raw_i >> 6) & 0x3FFFFFF
        
        # Uso do Opmap (Configurado via dicionário BGMI_TO_STD ou STD_TO_BGMI)
        sop = opmap.get(bop, bop)
        
        if bop >= 47 and bop not in BGMI_TO_STD:
            sop = bop
            fmt = 0
            stats['custom_preserved'] = stats.get('custom_preserved', 0) + 1
        else:
            fmt = STD_FMT[sop] if sop < len(STD_FMT) else 0
        
        inst_offset = len(w.b)
        inst_meta.append((inst_offset, sop, fmt, A, B, C, Bx, Bx - 131071, Ax, bop))
        w.instr(sop, A, B, C, Bx, Bx - 131071, Ax, fmt)

    # --- CONSTANTES ---
    nk = r.u32()
    if nk > 100000: nk = 0
    nk_off = len(w.b)
    w.u32(nk)
    ank = 0
    for _ in range(nk):
        if r.p >= r.max_p: break
        t = r.byte()
        w.byte(t)
        if t == 1: w.byte(r.byte())
        elif t == 3: w.f64(r.f64())
        elif t == 19: w.i64(r.i64())
        elif t in (4, 20): write_str(read_str())
        ank += 1
    w.b[nk_off:nk_off + 4] = struct.pack('<I', ank)

    # --- UPVALUES ---
    nups = r.u32()
    if nups > 1000: nups = 0
    w.u32(nups)
    for _ in range(nups):
        if r.p + 2 > r.max_p: break
        w.byte(r.byte()); w.byte(r.byte())

    # --- SUB-FUNÇÕES ---
    npts = r.u32()
    if npts > 1000: npts = 0
    npts_off = len(w.b)
    w.u32(npts)
    apts = 0
    for _ in range(npts):
        if r.p >= r.max_p: break
        _cvt_func(r, w, to_std, stats, op_map=op_map)
        apts += 1
    w.b[npts_off:npts_off + 4] = struct.pack('<I', apts)

    # --- LINHAS ---
    nln = r.u32()
    if nln > 100000: nln = 0
    nln_off = len(w.b)
    w.u32(nln)
    
    if to_std:
        lines = []
        cur = ldef_val
        for _ in range(nln):
            if r.p >= r.max_p: break
            d = r.byte()
            cur += d if d <= 127 else d - 256
            lines.append(cur)
        w.b[nln_off:nln_off + 4] = struct.pack('<I', len(lines))
        for ln in lines: w.i32(ln)
        nab = r.u32()
        if nab > 100000: nab = 0
        for _ in range(nab):
            if r.p + 8 > r.max_p: break
            r.u32(); r.u32()
    else:
        lines = [r.i32() for _ in range(nln)]
        w.b[nln_off:nln_off + 4] = struct.pack('<I', len(lines))
        prev = ldef_val
        for ln in lines:
            d = max(-128, min(127, ln - prev))
            prev = ln
            w.byte(d & 0xFF)
        w.u32(0)

    # --- NOMES ---
    nloc = r.u32()
    if nloc > 10000: nloc = 0
    w.u32(nloc)
    for _ in range(nloc):
        if r.p >= r.max_p: break
        write_str(read_str())
        w.i32(r.i32()); w.i32(r.i32())
    
    nupn = r.u32()
    if nupn > 1000: nupn = 0
    w.u32(nupn)
    for _ in range(nupn):
        if r.p >= r.max_p: break
        write_str(read_str())

    # --- CORREÇÕES ---
    if to_std:
        for idx, (off, op, fmt, A, B, C, Bx, sbx, Ax, original_bop) in enumerate(inst_meta):
            needs_fix = False
            new_A, new_B, new_C, new_Bx = A, B, C, Bx
            if A > 255: new_A = A & 0xFF; needs_fix = True
            if fmt in (1, 2):
                if op == 1 and Bx >= ank: new_Bx = max(0, min(Bx, ank - 1)); needs_fix = True
                if op == 44 and Bx >= apts: new_Bx = max(0, min(Bx, apts - 1)); needs_fix = True
                if op in (30, 39, 40, 42):
                    target = idx + 1 + sbx
                    if target < 0 or target >= csz:
                        new_Bx = (((-(idx + 1) if target < 0 else csz - idx - 2) + 131071) & 0x3FFFF); needs_fix = True
            elif fmt == 0:
                if (B & 0x100) and (B & 0xFF) >= ank: new_B = max(0, min(B & 0xFF, ank - 1)) | 0x100; needs_fix = True
                if (C & 0x100) and (C & 0xFF) >= ank: new_C = max(0, min(C & 0xFF, ank - 1)) | 0x100; needs_fix = True
            
            if needs_fix:
                stats['clamped'] = stats.get('clamped', 0) + 1
                fixed = (op & 0x3F) | ((new_A & 0xFF) << 6) | ((new_C & 0x1FF) << 14) | ((new_B & 0x1FF) << 23) if fmt == 0 else ((op & 0x3F) | ((new_A & 0xFF) << 6) | ((new_Bx & 0x3FFFF) << 14))
                w.b[off:off + 4] = struct.pack('<I', fixed)

def bgmi_to_std(data: bytes) -> Tuple[bytes, Dict, str]:
    
    if data[:4] != b'\x1bLua': raise ValueError(f"Invalid magic: {data[:4]}")
    r = _R(data, sizet=4)
    arch = "64-Bit" if len(r.d) > 13 and r.d[13] == 8 else "32-Bit"
    if len(r.d) > 33 and r.d[33] > 1:
        for i in range(33, min(len(r.d), 100)):
            r.d[i] = ((r.d[i] << 4) & 0xF0) | ((r.d[i] >> 4) & 0x0F)
    w = _W()
    hdr = bytearray(r.d[:HEADER_SIZE])
    hdr[13] = 4
    w.raw(hdr)
    r.p = HEADER_SIZE
    w.byte(r.byte())
    stats = {'clamped': 0, 'custom_preserved': 0}
    _cvt_func(r, w, to_std=True, stats=stats)
    return w.get(), stats, arch

def std_to_bgmi(data: bytes) -> bytes:
    """Convert standard Lua bytecode to BGMI format"""
    if data[:4] != b'\x1bLua': raise ValueError(f"Invalid magic: {data[:4]}")
    r = _R(data, sizet=4)
    w = _W()
    hdr = bytearray(data[:HEADER_SIZE])
    hdr[13] = 4
    w.raw(hdr)
    r.p = HEADER_SIZE
    w.byte(r.byte())
    _cvt_func(r, w, to_std=False, stats={'clamped': 0, 'custom_preserved': 0})
    return w.get()

def clean_pubg_map_garbage(content: str) -> str:
    """Remove garbage logs from unluac logs"""
    lines = content.split('\n')
    cleaned = []
    for line in lines:
        line = line.replace('No pubg_map.properties found. Using standard map.', '')
        line = line.replace('No pubg_map.properties found.', '')
        line = line.replace('pubg_map.properties', '')
        line = re.sub(r'--\s*Decompiled with unluac[^\n]*', '', line)
        if not line.strip(): continue
        cleaned.append(line)
    return '\n'.join(cleaned)

