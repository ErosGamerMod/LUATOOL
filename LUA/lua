def get_file_hash(filepath):
    """Get MD5 hash of a file"""
    if not filepath.exists():
        return None
    with open(filepath, 'rb') as f:
        return hashlib.md5(f.read()).hexdigest()

def load_opmap(filepath):
    """Carrega o arquivo de mapeamento de Opcodes da Tencent/BGMI."""
    mapping = {}
    try:
        # Usamos 'utf-8' para garantir leitura correta do arquivo de texto
        with open(filepath, 'r', encoding='utf-8') as f:
            for line in f:
                line = line.strip()
                # Validação estrita: processa apenas linhas iniciadas com .op
                if line.startswith('.op'):
                    parts = line.split() 
                    if len(parts) >= 3:
                        # Extrai o ID e o Mnemônico conforme estrutura do seu opmap.txt
                        opcode_id = int(parts[1])
                        mnemonic = parts[2]
                        mapping[opcode_id] = mnemonic
        
        if not mapping:
            print(f"  \033[1;33m[!!]\033[0m Atenção: O arquivo {filepath.name} está vazio ou mal formatado.")
        else:
            print(f"  \033[1;32m[OK]\033[0m Opcodes carregados: {len(mapping)} instruções mapeadas.")
        
        return mapping
    except Exception as e:
        print(f"  \033[1;31m[!!]\033[0m Erro fatal ao carregar {filepath.name}: {e}")
        return {}

