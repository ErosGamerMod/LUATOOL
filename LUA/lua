class _R:
    """Bytecode Reader"""
    def __init__(self, d: bytes, sizet: int = 4):
        self.d = bytearray(d)
        self.p = 0
        self.sizet = sizet
        self.max_p = len(d)
    
    def byte(self): 
        if self.p >= self.max_p:
            return 0
        v = self.d[self.p]
        self.p += 1
        return v
    
    def i32(self):
        if self.p + 4 > self.max_p:
            self.p = self.max_p
            return 0
        v = struct.unpack_from('<i', self.d, self.p)[0]
        self.p += 4
        return v
    
    def u32(self):
        if self.p + 4 > self.max_p:
            self.p = self.max_p
            return 0
        v = struct.unpack_from('<I', self.d, self.p)[0]
        self.p += 4
        return v
    
    def i64(self):
        if self.p + 8 > self.max_p:
            self.p = self.max_p
            return 0
        v = struct.unpack_from('<q', self.d, self.p)[0]
        self.p += 8
        return v
    
    def f64(self):
        if self.p + 8 > self.max_p:
            self.p = self.max_p
            return 0.0
        v = struct.unpack_from('<d', self.d, self.p)[0]
        self.p += 8
        return v
    
    def raw(self, n: int):
        if self.p + n > self.max_p:
            n = max(0, self.max_p - self.p)
        v = bytes(self.d[self.p:self.p + n])
        self.p += n
        return v
    
    def read(self, n: int):
        return self.raw(n)
    
    def bgmi_str(self):
        """Read BGMI encrypted string"""
        sz = self.byte()
        if sz == 0xFF: sz = self.u32()
        if sz == 0: return None
        enc = self.raw(sz - 1)
        decrypted = bytes(enc[i] ^ STRING_XOR_KEY[i % 32] for i in range(len(enc)))
        return decrypted.decode('utf-8', errors='replace')
    
    def std_str(self):
        """Read standard Lua string"""
        sz = self.byte()
        if sz == 0xFF:
            if self.sizet == 8:
                sz = struct.unpack_from('<Q', self.d, self.p)[0] if self.p + 8 <= self.max_p else 0
                self.p += 8
            else:
                sz = self.u32()
        if sz == 0: return None
        return self.raw(sz - 1).decode('utf-8', errors='replace')

class _W:
    """Bytecode Writer"""
    def __init__(self):
        self.b = bytearray()
    
    def byte(self, v): self.b.append(v & 0xFF)
    def i32(self, v): self.b.extend(struct.pack('<i', v))
    def u32(self, v): self.b.extend(struct.pack('<I', v))
    def i64(self, v): self.b.extend(struct.pack('<q', v))
    def f64(self, v): self.b.extend(struct.pack('<d', v))
    def raw(self, d): self.b.extend(d)
    
    def std_str(self, s):
        if s is None: self.byte(0); return
        e = s.encode('utf-8') if isinstance(s, str) else s
        sz = len(e) + 1
        if sz < 0xFF: self.byte(sz)
        else: self.byte(0xFF); self.u32(sz)
        self.raw(e)
    
    def bgmi_str(self, s):
        if s is None: self.byte(0); return
        p = s.encode('utf-8') if isinstance(s, str) else s
        e = bytes(p[i] ^ STRING_XOR_KEY[i % 32] for i in range(len(p)))
        sz = len(e) + 1
        if sz < 0xFF: self.byte(sz)
        else: self.byte(0xFF); self.u32(sz)
        self.raw(e)
    
    def instr(self, op, A, B, C, Bx, sBx, Ax, fmt):
        if fmt == 0:
            r = (op & 0x3F) | ((A & 0xFF) << 6) | ((C & 0x1FF) << 14) | ((B & 0x1FF) << 23)
        elif fmt == 1:
            r = (op & 0x3F) | ((A & 0xFF) << 6) | ((Bx & 0x3FFFF) << 14)
        elif fmt == 2:
            r = (op & 0x3F) | ((A & 0xFF) << 6) | (((sBx + 131071) & 0x3FFFF) << 14)
        else:
            r = (op & 0x3F) | ((Ax & 0x3FFFFFF) << 6)
        self.u32(r)
    
    def get(self): return bytes(self.b)

