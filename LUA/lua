class SimpleBgmiCompiler:
    def __init__(self, source_code: str, original_bgmi: bytes = None, compiler_path: str = None):
        self.source = source_code
        self.original_bgmi = original_bgmi
        self.compiler = compiler_path or find_compiler()

        self.instruction_patches = None
        self.meta = None

        if original_bgmi:
            tprint(" ", Theme.INFO)

            self.instruction_patches = extract_bgmi_instructions_simple(original_bgmi)

            total_custom = sum(
                func.get('custom_count', 0)
                for func in self.instruction_patches.values()
            )

            #tprint(
                #f"  📊 Found {total_custom} custom instructions in "
                #f"{len(self.instruction_patches)} functions",
                #Theme.INFO
            #)

    def compile(self) -> Tuple[bytes, Dict]:

        if not self.compiler:
            raise RuntimeError(
                "Lua compiler not found. Run: pkg install lua53"
            )

        # ==========================================================
        # STEP 1 — LUA → STD LUAC
        # ==========================================================

        tprint("  🛅 Motor ErosGamer Active...", Theme.INFO)

        std_bytecode = self._compile_to_std()

        # ==========================================================
        # STEP 2 — PATCH ORIGINAL BGMI STRUCTURE
        # ==========================================================

        if not self.original_bgmi:
            raise RuntimeError("Original BGMI file missing")

        tprint("", Theme.INFO)

        bgmi_bytecode = patch_bgmi_structure(
            std_bytecode,
            self.original_bgmi
        )

        # ==========================================================
        # STEP 3 — RESTORE CUSTOM BGMI OPCODES
        # ==========================================================

        restored_count = 0

        if self.instruction_patches:

            tprint(
                "",
                Theme.INFO
            )

            bgmi_bytecode, restored_count = (
                restore_bgmi_instructions_simple(
                    bgmi_bytecode,
                    self.instruction_patches
                )
            )

        # ==========================================================
        # STEP 4 — FINAL VALIDATION
        # ==========================================================

        if bgmi_bytecode[:4] != b'\x1bLua':
            raise RuntimeError("Final BGMI header invalid")

        # ==========================================================
        # STATS
        # ==========================================================

        stats = {
            'std_size': len(std_bytecode),
            'bgmi_size': len(bgmi_bytecode),
            'source_size': len(self.source),

            'compression_ratio': (
                len(bgmi_bytecode) / len(self.source)
                if self.source else 0
            ),

            'restored': restored_count > 0,
            'restored_count': restored_count,

            'functions_detected': (
                len(self.instruction_patches)
                if self.instruction_patches else 0
            )
        }

        return bgmi_bytecode, stats

    def _compile_to_std(self) -> bytes:
        tmp_lua = None
        tmp_luac = None
        
        try:
            import tempfile
            import subprocess
            from pathlib import Path
            
            with tempfile.NamedTemporaryFile(mode='w', delete=False, suffix=".lua", encoding='utf-8') as f:
                f.write(self.source)
                tmp_lua = f.name
                
            tmp_luac = tmp_lua + "c"

            # --- MODIFICAÇÃO AQUI: Apontando para o seu motor customizado ---
            motor_customizado = str(BIN_DIR / "luac")

            result = subprocess.run(
                [motor_customizado, "-s", "-o", tmp_luac, tmp_lua],
                capture_output=True, text=True, timeout=15
            )
            # ----------------------------------------------------------------

            if result.returncode != 0:
                raise RuntimeError(f"Compilation failed: {result.stderr[:200]}")

            bytecode = Path(tmp_luac).read_bytes()
            if bytecode[:4] != b'\x1bLua':
                raise RuntimeError("Invalid compiled header")

            return bytes(bytecode)
            
        finally:
            from pathlib import Path
            for f in [tmp_lua, tmp_luac]:
                if f and Path(f).exists():
                    try: 
                        Path(f).unlink()
                    except: 
                        pass


    def save_fixed_bytecode(self, bytecode: bytes, output_path: str):
        
        try:
            with open("funciona.lua", "rb") as f:
                header_fix = f.read(32)
        except:
            header_fix = b'\x00' * 32 
        
        final_data = header_fix + bytecode
        
        with open(output_path, "wb") as f:
            f.write(final_data)
        
        tprint(f"  ✅ Arquivo salvo com alinhamento de segurança em: {output_path}", Theme.SUCCESS)

    def compile(self, output_path: str = None) -> Tuple[bytes, Dict]:
