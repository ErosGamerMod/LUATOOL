        bgmi_bytecode = patch_bgmi_structure(std_bytecode, self.original_bgmi)

        # STEP 3
        restored_count = 0
        if self.instruction_patches:
            tprint("  ", Theme.INFO)
            bgmi_bytecode, restored_count = restore_bgmi_instructions_simple(
                bgmi_bytecode, 
                self.instruction_patches
            )

        # STEP 4
        if bgmi_bytecode[:4] != b'\x1bLua':
            raise RuntimeError("Final BGMI header invalid")
            
        # STEP 5: Salvar com o Header funcional (Padding)
        if output_path:
            self.save_fixed_bytecode(bgmi_bytecode, output_path)

        stats = {
            'std_size': len(std_bytecode),
            'bgmi_size': len(bgmi_bytecode),
            'source_size': len(self.source),
            'compression_ratio': (len(bgmi_bytecode) / len(self.source) if self.source else 0),
            'restored': restored_count > 0,
            'restored_count': restored_count,
            'functions_detected': (len(self.instruction_patches) if self.instruction_patches else 0)
        }

        return bgmi_bytecode, stats
                        
