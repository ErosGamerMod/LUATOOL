def extract_bgmi_instructions_simple(data: bytes) -> Dict:
    """Extract BGMI custom instructions safely without hanging"""
    if data[:4] != b'\x1bLua':
        raise ValueError("Not a valid Lua bytecode file")

    r = _R(data, sizet=4)
    r.p = HEADER_SIZE
    if r.p < r.max_p:
        r.byte()

    instruction_map = {}
    func_counter = [0]
    max_depth = 50
    max_functions = 1000

    def extract_func(r, func_id="main", depth=0):
        if depth > max_depth or func_counter[0] >= max_functions or r.p >= r.max_p:
            return
        func_counter[0] += 1
        try:
            try: r.bgmi_str()
            except: return
            r.i32(); r.i32()
            r.byte(); r.byte(); r.byte()

            code_size_pos = r.p
            code_size = r.u32()
            if code_size <= 0 or code_size > 100000:
                return

            custom_instructions = []
            for i in range(code_size):
                if r.p + 4 > r.max_p: break
                instr_offset = r.p
                raw_instr = r.u32()
                opcode = raw_instr & 0x3F
                std_opcode = BGMI_TO_STD.get(opcode, opcode)

                suspicious = False
                if std_opcode != opcode or opcode >= 47 or raw_instr == 0xFFFFFFFF or (raw_instr & 0x80000000):
                    suspicious = True

                if suspicious:
                    custom_instructions.append({
                        'index': i, 'offset': instr_offset, 'opcode': opcode,
                        'std_opcode': std_opcode, 'raw': raw_instr
                    })

            instruction_map[func_id] = {
                'offset': code_size_pos, 'code_size': code_size,
                'custom_count': len(custom_instructions), 'custom_instructions': custom_instructions
            }

            num_consts = r.u32()
            if num_consts < 0 or num_consts > 100000: num_consts = 0
            for _ in range(num_consts):
                if r.p >= r.max_p: break
                const_type = r.byte()
                if const_type == 1: r.byte()
                elif const_type == 3: r.f64()
                elif const_type == 19: r.i64()
                elif const_type in (4, 20): r.bgmi_str()

            num_upvals = r.u32()
            if num_upvals < 0 or num_upvals > 1000: num_upvals = 0
            for _ in range(num_upvals):
                if r.p + 2 > r.max_p: break
                r.byte(); r.byte()

            num_protos = r.u32()
            if num_protos < 0 or num_protos > 1000: num_protos = 0
            for i in range(num_protos):
                if r.p >= r.max_p: break
                extract_func(r, f"{func_id}.proto_{i}", depth + 1)

            num_lines = r.u32()
            if num_lines < 0 or num_lines > 100000: num_lines = 0
            for _ in range(num_lines):
                if r.p + 4 > r.max_p: break
                r.i32()

            num_abs = r.u32()
            if num_abs < 0 or num_abs > 100000: num_abs = 0
            for _ in range(num_abs):
                if r.p + 8 > r.max_p: break
                r.u32(); r.u32()

            num_locals = r.u32()
            if num_locals < 0 or num_locals > 10000: num_locals = 0
            for _ in range(num_locals):
                if r.p >= r.max_p: break
                r.bgmi_str(); r.i32(); r.i32()

            num_upval_names = r.u32()
            if num_upval_names < 0 or num_upval_names > 1000: num_upval_names = 0
            for _ in range(num_upval_names):
                if r.p >= r.max_p: break
                r.bgmi_str()
        except:
            return

    extract_func(r)
    return instruction_map
    
def restore_bgmi_instructions_simple(bgmi_data: bytes, original_instructions: Dict):
